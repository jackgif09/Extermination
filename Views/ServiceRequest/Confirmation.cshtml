@model ServiceRequest
@{
    ViewData["Title"] = "Request Submitted";
}

<section class="py-16 px-4">
    <div class="max-w-xl mx-auto bg-white rounded-2xl shadow-md p-10 text-center">

        <!-- Checkmark -->
        <div class="flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mx-auto mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
        </div>

        <h1 class="text-2xl font-extrabold text-slate-900 mb-1">Request Submitted!</h1>
        <p class="text-slate-500 mb-8">
            Thank you, <span class="font-semibold text-slate-800">@Model.CustomerName</span>. We'll reach out to confirm your appointment shortly.
        </p>

        <!-- Summary -->
        <div class="bg-gray-50 rounded-xl p-5 text-left mb-8 space-y-3">
            <div class="flex justify-between text-sm">
                <span class="text-slate-500">Reference #</span>
                <span class="font-semibold text-slate-800">#@Model.Id</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-slate-500">Pest Type</span>
                <span class="font-semibold text-slate-800">@Model.PestType.ToString().Replace("_", " ")</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-slate-500">Service Address</span>
                <span class="font-semibold text-slate-800 text-right max-w-[60%]">@Model.Address</span>
            </div>
            @if (Model.PreferredDate.HasValue)
            {
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Preferred Date</span>
                    <span class="font-semibold text-slate-800">@Model.PreferredDate.Value.ToString("MMMM d, yyyy")</span>
                </div>
            }
            <div class="flex justify-between text-sm items-center">
                <span class="text-slate-500">Status</span>
                <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded-full">New</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-3">
            <a asp-controller="ServiceRequest" asp-action="Create"
               class="flex-1 bg-amber-500 hover:bg-amber-400 text-white font-semibold py-3 rounded-lg text-sm text-center transition-colors">
                Submit Another Request
            </a>
            <a asp-controller="Home" asp-action="Index"
               class="flex-1 border border-slate-300 hover:border-slate-400 text-slate-700 font-semibold py-3 rounded-lg text-sm text-center transition-colors">
                Back to Home
            </a>
        </div>

    </div>
</section>
