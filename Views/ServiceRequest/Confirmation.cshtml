@model ServiceRequest
@{
    ViewData["Title"] = "Request Submitted";
}

<div class="max-w-md mx-auto px-6 py-20 text-center">

    <svg class="w-10 h-10 text-green-600 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>

    <h1 class="text-2xl font-bold text-gray-900 mb-3">Got it, @Model.CustomerName.</h1>
    <p class="text-gray-500 leading-relaxed mb-10">
        I'll call or text you within a few hours to confirm a time. If it's urgent, feel free to call me directly at <a href="tel:5551234567" class="text-green-700 hover:underline">(555) 123-4567</a>.
    </p>

    <dl class="text-left space-y-3 mb-10">
        <div class="flex justify-between text-sm">
            <dt class="text-gray-400">Reference</dt>
            <dd class="text-gray-700 font-medium">#@Model.Id</dd>
        </div>
        <div class="flex justify-between text-sm">
            <dt class="text-gray-400">Pest type</dt>
            <dd class="text-gray-700 font-medium">@Model.PestType.ToString().Replace("_", " ")</dd>
        </div>
        <div class="flex justify-between text-sm gap-4">
            <dt class="text-gray-400 shrink-0">Address</dt>
            <dd class="text-gray-700 font-medium text-right">@Model.Address</dd>
        </div>
        @if (Model.PreferredDate.HasValue)
        {
            <div class="flex justify-between text-sm">
                <dt class="text-gray-400">Preferred date</dt>
                <dd class="text-gray-700 font-medium">@Model.PreferredDate.Value.ToString("MMMM d, yyyy")</dd>
            </div>
        }
    </dl>

    <a asp-controller="Home" asp-action="Index"
       class="inline-block bg-green-700 hover:bg-green-800 text-white font-medium px-7 py-3.5 rounded-xl text-sm transition-colors">
        Back to Home
    </a>
    <p class="mt-4 text-sm text-gray-400">
        <a asp-controller="ServiceRequest" asp-action="Create"
           class="hover:text-gray-600 underline underline-offset-2 transition-colors">Submit another request</a>
    </p>

</div>
