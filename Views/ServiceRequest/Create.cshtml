@model ServiceRequest
@{
    ViewData["Title"] = "Request Service";
}

<!-- Page header -->
<div class="bg-white border-b border-gray-200 px-6 py-12">
    <div class="max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-green-800 mb-3">Service Request</p>
        <h1 class="text-3xl font-bold text-gray-900">Request a Service Visit</h1>
        <p class="text-gray-500 mt-2">Complete the form below and we will contact you to confirm your appointment within the hour.</p>
    </div>
</div>

<section class="bg-gray-50 px-6 py-12">
    <div class="max-w-2xl mx-auto">

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="border border-red-300 bg-red-50 text-red-700 text-sm rounded px-5 py-4 mb-8">
                <p class="font-semibold mb-1">Please correct the following errors:</p>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Create" asp-controller="ServiceRequest" method="post" novalidate
              class="bg-white border border-gray-200 rounded p-8 md:p-10">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

                <!-- Customer Name -->
                <div class="sm:col-span-2">
                    <label asp-for="CustomerName" class="block text-sm font-medium text-gray-700 mb-1.5">Full Name</label>
                    <input asp-for="CustomerName" type="text" placeholder="Jane Smith"
                           class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition" />
                    <span asp-validation-for="CustomerName" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

                <!-- Phone -->
                <div>
                    <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone Number</label>
                    <input asp-for="Phone" type="tel" placeholder="(555) 000-0000"
                           class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition" />
                    <span asp-validation-for="Phone" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address</label>
                    <input asp-for="Email" type="email" placeholder="you@example.com"
                           class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition" />
                    <span asp-validation-for="Email" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

                <!-- Address -->
                <div class="sm:col-span-2">
                    <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1.5">Service Address</label>
                    <input asp-for="Address" type="text" placeholder="123 Main St, Springfield, IL 62701"
                           class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition" />
                    <span asp-validation-for="Address" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

                <!-- Pest Type -->
                <div>
                    <label asp-for="PestType" class="block text-sm font-medium text-gray-700 mb-1.5">Type of Pest</label>
                    <select asp-for="PestType" asp-items="Html.GetEnumSelectList<PestType>()"
                            class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm bg-white focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition">
                        <option value="" disabled selected>Select a pest type...</option>
                    </select>
                    <span asp-validation-for="PestType" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

                <!-- Preferred Date -->
                <div>
                    <label asp-for="PreferredDate" class="block text-sm font-medium text-gray-700 mb-1.5">
                        Preferred Date
                        <span class="text-gray-400 font-normal">(optional)</span>
                    </label>
                    <input asp-for="PreferredDate" type="date"
                           class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition" />
                    <span asp-validation-for="PreferredDate" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

                <!-- Description -->
                <div class="sm:col-span-2">
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1.5">
                        Description
                        <span class="text-gray-400 font-normal">(optional)</span>
                    </label>
                    <textarea asp-for="Description" rows="4"
                              placeholder="Describe where you have seen the pests, how long the problem has been occurring, and any relevant details about your property."
                              class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-green-800 focus:border-green-800 transition resize-y"></textarea>
                    <span asp-validation-for="Description" class="text-red-600 text-xs mt-1.5 block"></span>
                </div>

            </div>

            <div class="mt-8 pt-6 border-t border-gray-100">
                <button type="submit"
                        class="w-full bg-green-800 hover:bg-green-900 text-white font-medium py-3.5 rounded text-sm transition-colors">
                    Submit Request
                </button>
                <p class="text-center text-xs text-gray-400 mt-3">We will respond within one hour during business hours.</p>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
