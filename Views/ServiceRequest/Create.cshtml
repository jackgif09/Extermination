@model ServiceRequest
@{
    ViewData["Title"] = "Request Service";
}

<!-- Page header -->
<section class="bg-green-700 text-white py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-3xl font-extrabold mb-1">Request Pest Control Service</h1>
        <p class="text-green-200">Fill out the form below and we'll contact you to confirm your appointment.</p>
    </div>
</section>

<section class="py-12 px-4">
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-md p-8">

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="bg-red-50 border border-red-300 text-red-700 text-sm rounded-lg p-4 mb-6">
                <p class="font-semibold mb-1">Please correct the errors below:</p>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Create" asp-controller="ServiceRequest" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                <!-- Customer Name -->
                <div class="sm:col-span-2">
                    <label asp-for="CustomerName" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
                    <input asp-for="CustomerName" type="text" placeholder="Jane Smith"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition" />
                    <span asp-validation-for="CustomerName" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Phone -->
                <div>
                    <label asp-for="Phone" class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
                    <input asp-for="Phone" type="tel" placeholder="(555) 000-0000"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition" />
                    <span asp-validation-for="Phone" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                    <input asp-for="Email" type="email" placeholder="you@example.com"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition" />
                    <span asp-validation-for="Email" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Address -->
                <div class="sm:col-span-2">
                    <label asp-for="Address" class="block text-sm font-medium text-slate-700 mb-1">Service Address</label>
                    <input asp-for="Address" type="text" placeholder="123 Main St, Springfield, IL 62701"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition" />
                    <span asp-validation-for="Address" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Pest Type -->
                <div>
                    <label asp-for="PestType" class="block text-sm font-medium text-slate-700 mb-1">Type of Pest</label>
                    <select asp-for="PestType" asp-items="Html.GetEnumSelectList<PestType>()"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition bg-white">
                        <option value="" disabled selected>Select a pest...</option>
                    </select>
                    <span asp-validation-for="PestType" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Preferred Date -->
                <div>
                    <label asp-for="PreferredDate" class="block text-sm font-medium text-slate-700 mb-1">Preferred Date <span class="text-slate-400 font-normal">(optional)</span></label>
                    <input asp-for="PreferredDate" type="date"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition" />
                    <span asp-validation-for="PreferredDate" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Description -->
                <div class="sm:col-span-2">
                    <label asp-for="Description" class="block text-sm font-medium text-slate-700 mb-1">Description <span class="text-slate-400 font-normal">(optional)</span></label>
                    <textarea asp-for="Description" rows="4" placeholder="Describe where you've seen the pests, how long the problem has been occurring, etc."
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition resize-y"></textarea>
                    <span asp-validation-for="Description" class="text-red-600 text-xs mt-1 block"></span>
                </div>

            </div>

            <button type="submit"
                    class="w-full mt-6 bg-green-700 hover:bg-green-800 text-white font-semibold py-3 rounded-lg transition-colors text-sm">
                Submit Request &rarr;
            </button>
        </form>

    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
