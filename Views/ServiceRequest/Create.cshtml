@model ServiceRequest
@{
    ViewData["Title"] = "Book Service";
}

<div class="max-w-xl mx-auto px-6 py-16">

    <h1 class="text-2xl font-bold text-gray-900 mb-2">Book a service call</h1>
    <p class="text-gray-500 mb-10 leading-relaxed">Fill in the form and I'll call or text you back within a few hours to confirm a time. No commitment until we talk.</p>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-5 py-4 mb-8">
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    <form asp-action="Create" asp-controller="ServiceRequest" method="post" novalidate class="space-y-5">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            <div class="sm:col-span-2">
                <label asp-for="CustomerName" class="block text-sm font-medium text-gray-700 mb-1.5">Your name</label>
                <input asp-for="CustomerName" type="text" placeholder="Jane Smith"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition" />
                <span asp-validation-for="CustomerName" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone number</label>
                <input asp-for="Phone" type="tel" placeholder="(555) 000-0000"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition" />
                <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1.5">Email address</label>
                <input asp-for="Email" type="email" placeholder="you@example.com"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition" />
                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="sm:col-span-2">
                <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1.5">Service address</label>
                <input asp-for="Address" type="text" placeholder="123 Main St, Springfield, IL 62701"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition" />
                <span asp-validation-for="Address" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="PestType" class="block text-sm font-medium text-gray-700 mb-1.5">Type of pest</label>
                <select asp-for="PestType" asp-items="Html.GetEnumSelectList<PestType>()"
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition">
                    <option value="" disabled selected>Select a pest...</option>
                </select>
                <span asp-validation-for="PestType" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="PreferredDate" class="block text-sm font-medium text-gray-700 mb-1.5">
                    Preferred date <span class="text-gray-400 font-normal">(optional)</span>
                </label>
                <input asp-for="PreferredDate" type="date"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition" />
                <span asp-validation-for="PreferredDate" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="sm:col-span-2">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1.5">
                    Tell me more <span class="text-gray-400 font-normal">(optional)</span>
                </label>
                <textarea asp-for="Description" rows="4"
                          placeholder="Where have you seen them? How long has this been going on? Anything else I should know before I come out."
                          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition resize-y"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
            </div>

        </div>

        <button type="submit"
                class="w-full bg-green-700 hover:bg-green-800 text-white font-medium py-3.5 rounded-xl text-sm transition-colors mt-2">
            Submit Request
        </button>

        <p class="text-xs text-gray-400 text-center">I'll be in touch within a few hours. No spam, ever.</p>

    </form>

</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
