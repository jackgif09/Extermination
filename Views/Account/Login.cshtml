@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Cime-X Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('adminTheme');
            if (t) document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>
<body class="app-body">

    <div class="login-page">
        <div class="login-card">
            <h1 class="login-title">Cime-X Admin</h1>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="login-error"></div>

                <div class="form-group" style="margin-bottom: 1rem">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" class="form-input" autocomplete="username" />
                    <span asp-validation-for="Username" class="form-error"></span>
                </div>

                <div class="form-group" style="margin-bottom: 1rem">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-input" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="form-error"></span>
                </div>

                <div style="margin-bottom: 1.25rem">
                    <label style="display: flex; align-items: center; gap: .5rem; font-size: 13px; cursor: pointer; color: var(--a-text-2)">
                        <input asp-for="RememberMe" type="checkbox" />
                        Keep me signed in
                    </label>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center">
                    Sign In
                </button>
            </form>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
