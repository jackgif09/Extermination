<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BugOff Exterminators</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="bg-white text-gray-900 min-h-screen flex flex-col">

    <header class="sticky top-0 z-50 bg-white border-b border-gray-100">
        <div class="max-w-6xl mx-auto px-6">
            <div class="flex items-center justify-between h-16">

                <a asp-controller="Home" asp-action="Index"
                   class="font-semibold text-gray-900 hover:text-green-700 transition-colors">
                    BugOff Exterminators
                </a>

                <nav class="hidden md:flex items-center gap-7">
                    <a asp-controller="Home" asp-action="Index"
                       class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Home</a>
                    <a asp-controller="Home" asp-action="ServiceArea"
                       class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Service Area</a>
                    <a asp-controller="Home" asp-action="Rates"
                       class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Rates</a>
                    <a asp-controller="Home" asp-action="Reviews"
                       class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Reviews</a>
                    <a asp-controller="Home" asp-action="Contact"
                       class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Contact</a>
                    <a asp-controller="ServiceRequest" asp-action="Create"
                       class="bg-green-700 hover:bg-green-800 text-white text-sm font-medium px-5 py-2 rounded-xl transition-colors">
                        Book Service
                    </a>
                </nav>

                <button id="menu-toggle"
                        class="md:hidden text-gray-400 hover:text-gray-700 focus:outline-none"
                        aria-label="Toggle navigation" aria-expanded="false">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M4 6h16M4 12h16M4 18h16" />
                        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 py-5 flex flex-col gap-4">
                <a asp-controller="Home" asp-action="Index"
                   class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Home</a>
                <a asp-controller="Home" asp-action="ServiceArea"
                   class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Service Area</a>
                <a asp-controller="Home" asp-action="Rates"
                   class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Rates</a>
                <a asp-controller="Home" asp-action="Reviews"
                   class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Reviews</a>
                <a asp-controller="Home" asp-action="Contact"
                   class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
                <a asp-controller="ServiceRequest" asp-action="Create"
                   class="bg-green-700 hover:bg-green-800 text-white text-sm font-medium px-5 py-2.5 rounded-xl text-center transition-colors">
                    Book Service
                </a>
            </div>
        </div>
    </header>

    <main class="flex-1">
        @RenderBody()
    </main>

    <footer class="bg-gray-900 text-gray-400 mt-auto">
        <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-10">
            <div>
                <p class="text-white font-semibold mb-1">BugOff Exterminators</p>
                <p class="text-sm text-gray-500 italic mb-4">Peace of Mind</p>
                <p class="text-sm leading-relaxed">Licensed and insured pest control for central Illinois homes and businesses.</p>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-300 mb-3">Contact</p>
                <p class="text-sm mb-2"><a href="tel:5551234567" class="hover:text-white transition-colors">(555) 123-4567</a></p>
                <p class="text-sm mb-2"><a href="mailto:info@bugoff.com" class="hover:text-white transition-colors">info@bugoff.com</a></p>
                <p class="text-sm text-gray-500">Mon&ndash;Sat &nbsp;7am&ndash;7pm</p>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-300 mb-3">Service Area</p>
                <p class="text-sm leading-relaxed">Springfield, Shelbyville, Capital City, and surrounding central Illinois communities.</p>
                <a asp-controller="Home" asp-action="ServiceArea"
                   class="inline-block mt-3 text-sm text-green-500 hover:text-green-400 transition-colors">View map &rarr;</a>
            </div>
        </div>
        <div class="border-t border-gray-800 py-4 text-center text-xs text-gray-600">
            &copy; @DateTime.Now.Year BugOff Exterminators &middot;
            <a asp-controller="Admin" asp-action="Index" class="hover:text-gray-400 transition-colors">Admin</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var toggle = document.getElementById('menu-toggle');
            var menu = document.getElementById('mobile-menu');
            var hamburger = document.getElementById('hamburger-icon');
            var close = document.getElementById('close-icon');
            toggle.addEventListener('click', function () {
                var isOpen = !menu.classList.contains('hidden');
                menu.classList.toggle('hidden');
                hamburger.classList.toggle('hidden', !isOpen);
                close.classList.toggle('hidden', isOpen);
                toggle.setAttribute('aria-expanded', String(!isOpen));
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
