<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cime-X</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="bg-[#e8edea] text-gray-900 min-h-screen flex flex-col">

    <header class="border-b border-[#d0dbd4]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex items-center justify-between h-16">

                <a asp-controller="Home" asp-action="Index"
                   class="text-lg font-semibold tracking-tight text-gray-900 hover:text-green-800 transition-colors">
                    Cime-X
                </a>

                <nav class="hidden lg:flex items-center gap-6">
                    <a asp-controller="Home" asp-action="Index"
                       class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Pest Control</a>
                    <a asp-controller="Home" asp-action="ServiceArea"
                       class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Service Area</a>
                    <a asp-controller="Home" asp-action="Rates"
                       class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Rates</a>
                    <a asp-controller="Home" asp-action="CommercialLicenses"
                       class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Commercial Licenses</a>
                    <a asp-controller="Home" asp-action="Reviews"
                       class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Reviews</a>
                    <a asp-controller="Home" asp-action="Contact"
                       class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
                    <a asp-controller="ServiceRequest" asp-action="Create"
                       class="bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                        Book Service
                    </a>
                </nav>

                <button id="menu-toggle"
                        class="lg:hidden text-gray-500 hover:text-gray-800 focus:outline-none"
                        aria-label="Toggle navigation" aria-expanded="false">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M4 6h16M4 12h16M4 18h16" />
                        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div id="mobile-menu" class="hidden lg:hidden border-t border-[#d0dbd4] py-5 flex flex-col gap-4">
                <a asp-controller="Home" asp-action="Index"
                   class="text-sm text-gray-700 hover:text-gray-900 transition-colors">Pest Control</a>
                <a asp-controller="Home" asp-action="ServiceArea"
                   class="text-sm text-gray-700 hover:text-gray-900 transition-colors">Service Area</a>
                <a asp-controller="Home" asp-action="Rates"
                   class="text-sm text-gray-700 hover:text-gray-900 transition-colors">Rates</a>
                <a asp-controller="Home" asp-action="CommercialLicenses"
                   class="text-sm text-gray-700 hover:text-gray-900 transition-colors">Commercial Licenses</a>
                <a asp-controller="Home" asp-action="Reviews"
                   class="text-sm text-gray-700 hover:text-gray-900 transition-colors">Reviews</a>
                <a asp-controller="Home" asp-action="Contact"
                   class="text-sm text-gray-700 hover:text-gray-900 transition-colors">Contact</a>
                <a asp-controller="ServiceRequest" asp-action="Create"
                   class="bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg text-center transition-colors">
                    Book Service
                </a>
            </div>
        </div>
    </header>

    <main class="flex-1">
        @RenderBody()
    </main>

    <footer class="border-t border-[#d0dbd4] mt-auto">
        <div class="max-w-7xl mx-auto px-6 py-10 text-center">
            <p class="text-lg font-semibold text-gray-900 mb-1">Cime-X</p>
            <p class="text-sm text-gray-600 mb-1">Clintonville Pest Control</p>
            <p class="text-sm text-gray-500 italic mb-6">Peace of Mind</p>
            <p class="text-xs text-gray-400">
                &copy; @DateTime.Now.Year Cime-X &middot;
                <a asp-controller="Admin" asp-action="Index" class="hover:text-gray-600 transition-colors">Admin</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var toggle = document.getElementById('menu-toggle');
            var menu = document.getElementById('mobile-menu');
            var hamburger = document.getElementById('hamburger-icon');
            var close = document.getElementById('close-icon');
            toggle.addEventListener('click', function () {
                var isOpen = !menu.classList.contains('hidden');
                menu.classList.toggle('hidden');
                hamburger.classList.toggle('hidden', !isOpen);
                close.classList.toggle('hidden', isOpen);
                toggle.setAttribute('aria-expanded', String(!isOpen));
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
