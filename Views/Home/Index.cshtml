@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- Hero -->
<section class="px-6 py-24 max-w-5xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-snug mb-5">
        Pest problems?<br />We can help.
    </h1>
    <p class="text-gray-500 text-lg leading-relaxed max-w-xl mb-8">
        BugOff Exterminators has been keeping central Illinois homes and businesses pest-free since 2008. Fast, friendly, and guaranteed.
    </p>
    <a asp-controller="ServiceRequest" asp-action="Create"
       class="inline-block bg-green-700 hover:bg-green-800 text-white font-medium px-7 py-3.5 rounded-xl text-sm transition-colors">
        Request a Visit
    </a>
    <p class="mt-4 text-sm text-gray-400">
        Or call us at <a href="tel:5551234567" class="text-gray-600 hover:text-green-700 transition-colors">(555) 123-4567</a>
    </p>
</section>

<!-- What we do -->
<section class="px-6 pb-24 max-w-5xl mx-auto">
    <div class="border-t border-gray-100 pt-16">

        <h2 class="text-xl font-semibold text-gray-900 mb-3">Pests we treat</h2>
        <p class="text-gray-500 leading-relaxed mb-16">
            Ants &middot; Bed Bugs &middot; Cockroaches &middot; Fleas &middot; Mosquitoes &middot; Rodents &middot; Spiders &middot; Termites &middot; Wasps &middot; and more
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            <div>
                <h3 class="font-semibold text-gray-900 mb-2">Licensed &amp; Insured</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Every technician is state-certified and fully insured. You are always in good hands.</p>
            </div>
            <div>
                <h3 class="font-semibold text-gray-900 mb-2">Same-Day Response</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Most requests are scheduled within 24 hours. We know pest problems can't wait.</p>
            </div>
            <div>
                <h3 class="font-semibold text-gray-900 mb-2">Safe for Your Family</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Our treatments are low-impact and eco-friendly&mdash;effective on pests, gentle on people and pets.</p>
            </div>
        </div>

    </div>
</section>
