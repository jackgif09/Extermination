@{
    ViewData["Title"] = "Clintonville Area Pest Control";
}

<div class="max-w-3xl mx-auto px-6 py-16 text-center">

    <!-- Heading -->
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-10">
        Cime-X: Clintonville Area Pest Control
    </h1>

    <!-- Logo -->
    <div class="flex justify-center mb-10">
        <img src="~/images/cime-x-logo.jpg"
             alt="Cime-X Pest Control Logo"
             class="max-w-xs sm:max-w-sm w-full h-auto" />
    </div>

    <!-- IPM description -->
    <p class="text-base text-gray-700 leading-relaxed mb-10 max-w-2xl mx-auto">
        An Integrated Pest Management System that includes habitat modification, food source and moisture removal, traps, heat, physical removal, repairs, and organic and chemical treatment.
    </p>

    <!-- Pest list -->
    <div class="mb-14">
        <p class="text-sm text-gray-600 leading-relaxed">
            Ants &middot; Bedbugs &middot; Beetles &middot; Box Elder Bugs &middot; Cockroaches &middot; Crickets &middot;
            Earwigs &middot; Fleas &middot; Flies &middot; Gnats &middot; Grubs &middot; Hornets &middot; Lady Bugs &middot;
            Millipedes &middot; Mice &middot; Mites &middot; Mosquitoes &middot; Moths &middot; Rats &middot; Spiders &middot;
            Spotted Lantern Flies &middot; Spring Tails &middot; Stinging Insects &middot; Stored Product Pests &middot;
            Termites &middot; Ticks &middot; Turf Pests &middot; Vector Pests &middot; Voles &middot; Wasps &middot;
            Yellow Jackets &middot; and MORE.
        </p>
    </div>

    <!-- Peace of Mind -->
    <div class="border-t border-[#d0dbd4] pt-12">
        <p class="text-xl sm:text-2xl font-semibold text-gray-900 mb-4">Peace of Mind</p>
        <p class="text-base text-gray-600 leading-relaxed max-w-xl mx-auto">
            I want to help protect your home, ease your worries, keep your bugs private, and prevent pests from returning.
        </p>
        <a asp-controller="ServiceRequest" asp-action="Create"
           class="inline-block mt-8 bg-gray-900 hover:bg-gray-700 text-white font-medium px-8 py-3.5 rounded-lg text-sm transition-colors">
            Book a Service Call
        </a>
    </div>

</div>
