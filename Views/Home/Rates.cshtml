@{
    ViewData["Title"] = "Rates";
}

<div class="max-w-6xl mx-auto px-6 py-16">

    <h1 class="text-3xl font-bold text-gray-900 mb-3">Rates</h1>
    <p class="text-gray-600 mb-12 max-w-xl">Straightforward pricing. No hidden fees, no upsells. If your situation needs something different, I'll quote it before I start.</p>

    <!-- Residential -->
    <section class="mb-14">
        <h2 class="text-base font-semibold text-gray-900 mb-5">Residential services</h2>
        <div class="overflow-x-auto rounded-2xl border border-gray-100">
            <table class="w-full text-sm text-left bg-white">
                <thead>
                    <tr class="border-b border-gray-100 text-gray-600 text-xs">
                        <th class="px-5 py-3.5 font-medium">Service</th>
                        <th class="px-5 py-3.5 font-medium">Includes</th>
                        <th class="px-5 py-3.5 font-medium text-right">Price</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <tr>
                        <td class="px-5 py-4 font-medium text-gray-900">General pest control</td>
                        <td class="px-5 py-4 text-gray-500">Interior + exterior treatment, follow-up visit</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$120</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 font-medium text-gray-900">Rodent control</td>
                        <td class="px-5 py-4 text-gray-500">Inspection, trapping, entry-point recommendations</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$150</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 font-medium text-gray-900">Bed bug treatment</td>
                        <td class="px-5 py-4 text-gray-500">Full room treatment, follow-up inspection</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">From $250</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 font-medium text-gray-900">Termite inspection</td>
                        <td class="px-5 py-4 text-gray-500">Written report, treatment quote if needed</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$75</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 font-medium text-gray-900">Wasp / hornet removal</td>
                        <td class="px-5 py-4 text-gray-500">Nest removal, same-day available</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$95</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 font-medium text-gray-900">Mosquito treatment</td>
                        <td class="px-5 py-4 text-gray-500">Yard spray, barrier treatment, seasonal plan available</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$85</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- Other -->
    <section class="mb-14">
        <h2 class="text-base font-semibold text-gray-900 mb-5">Add-ons &amp; other services</h2>
        <div class="overflow-x-auto rounded-2xl border border-gray-100">
            <table class="w-full text-sm text-left bg-white">
                <thead>
                    <tr class="border-b border-gray-100 text-gray-600 text-xs">
                        <th class="px-5 py-3.5 font-medium">Service</th>
                        <th class="px-5 py-3.5 font-medium text-right">Price</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <tr>
                        <td class="px-5 py-4 text-gray-700">Additional follow-up visit</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$45</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 text-gray-700">Real estate / pre-sale inspection</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$85</td>
                    </tr>
                    <tr>
                        <td class="px-5 py-4 text-gray-700">Preventive perimeter treatment</td>
                        <td class="px-5 py-4 text-gray-900 text-right font-medium">$65</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- Commercial -->
    <section class="mb-14">
        <h2 class="text-base font-semibold text-gray-900 mb-3">Commercial</h2>
        <p class="text-sm text-gray-600 max-w-xl leading-relaxed">
            Commercial pricing depends on square footage, pest type, and frequency. I work with restaurants, property managers, and small offices. Call or send me a message for a quote.
        </p>
    </section>

    <!-- Payment -->
    <section class="mb-14 pt-10 border-t border-gray-100">
        <h2 class="text-base font-semibold text-gray-900 mb-3">Payment</h2>
        <p class="text-sm text-gray-600 leading-relaxed">Cash, check, Venmo, and all major credit cards accepted. Payment is due at time of service.</p>
    </section>

    <p class="text-sm text-gray-600 max-w-lg leading-relaxed">
        Prices listed are starting rates for standard residential situations. Larger homes, severe infestations, or unusual access may affect the final cost. I'll always discuss price before starting work.
    </p>

    <div class="mt-12">
        <a asp-controller="ServiceRequest" asp-action="Create"
           class="inline-block bg-green-700 hover:bg-green-800 text-white font-medium px-7 py-3 rounded-xl text-sm transition-colors">
            Book a Service Call
        </a>
    </div>

</div>
