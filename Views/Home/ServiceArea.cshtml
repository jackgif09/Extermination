@{
    ViewData["Title"] = "Service Area";
}

<div class="max-w-6xl mx-auto px-6 py-16">

    <h1 class="text-3xl font-bold text-gray-900 mb-3">Service Area</h1>
    <p class="text-gray-600 mb-12 max-w-xl">I serve most of central Illinois within about 40 miles of Springfield. If you're not sure whether I cover your area, just call — I'll let you know straight away.</p>

    <!-- Map placeholder -->
    <div class="w-full h-80 bg-gray-100 rounded-2xl flex items-center justify-center mb-12">
        <p class="text-gray-600 text-sm">Map coming soon</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12 max-w-2xl">
        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-4">Cities and towns I regularly serve</h2>
            <ul class="text-sm text-gray-600 space-y-2 leading-relaxed">
                <li>Springfield</li>
                <li>Chatham</li>
                <li>Sherman</li>
                <li>Rochester</li>
                <li>Pawnee</li>
                <li>Taylorville</li>
                <li>Litchfield</li>
                <li>Lincoln</li>
                <li>Jacksonville</li>
                <li>Beardstown</li>
            </ul>
        </div>
        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-4">Trip fees</h2>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">
                No trip fee within 20 miles of Springfield. A $25 trip fee applies for locations 20–40 miles out.
            </p>
            <p class="text-sm text-gray-600 leading-relaxed">
                I occasionally travel further for larger jobs — contact me and we'll work something out.
            </p>
        </div>
    </div>

    <div class="mt-14 pt-10 border-t border-gray-100">
        <p class="text-sm text-gray-600 mb-5">Ready to book, or just have a question?</p>
        <div class="flex flex-col sm:flex-row gap-4">
            <a asp-controller="ServiceRequest" asp-action="Create"
               class="inline-block bg-green-700 hover:bg-green-800 text-white font-medium px-7 py-3 rounded-xl text-sm transition-colors text-center">
                Book Service
            </a>
            <a href="tel:5551234567"
               class="inline-block border border-gray-200 hover:border-gray-400 text-gray-700 font-medium px-7 py-3 rounded-xl text-sm transition-colors text-center">
                (555) 123-4567
            </a>
        </div>
    </div>

</div>
