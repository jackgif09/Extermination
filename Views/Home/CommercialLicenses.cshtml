@{
    ViewData["Title"] = "Commercial Licenses";
}

<div class="max-w-3xl mx-auto px-6 py-16">

    <h1 class="text-3xl font-bold text-gray-900 mb-3 text-center">Commercial Licenses</h1>
    <p class="text-gray-600 text-center mb-14 max-w-xl mx-auto">Licensed and certified for commercial pest control in Wisconsin. I work with restaurants, property managers, offices, and other commercial accounts.</p>

    <div class="space-y-8 max-w-xl mx-auto">

        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-2">Wisconsin Commercial Pesticide Applicator</h2>
            <p class="text-sm text-gray-600 leading-relaxed">Licensed by the Wisconsin Department of Agriculture, Trade and Consumer Protection (DATCP) for commercial pesticide application.</p>
        </div>

        <div class="border-t border-[#d0dbd4] pt-8">
            <h2 class="text-base font-semibold text-gray-900 mb-2">IPM Certified</h2>
            <p class="text-sm text-gray-600 leading-relaxed">Trained in Integrated Pest Management principles — a science-based approach that minimizes risk to people, property, and the environment.</p>
        </div>

        <div class="border-t border-[#d0dbd4] pt-8">
            <h2 class="text-base font-semibold text-gray-900 mb-2">Commercial accounts</h2>
            <p class="text-sm text-gray-600 leading-relaxed mb-3">I provide service contracts for commercial properties including restaurants, food service facilities, multi-family housing, offices, and retail spaces. Contact me to discuss your needs and schedule a site assessment.</p>
        </div>

    </div>

    <div class="mt-14 text-center">
        <a asp-controller="Home" asp-action="Contact"
           class="inline-block border border-gray-400 hover:border-gray-700 text-gray-700 font-medium px-7 py-3 rounded-lg text-sm transition-colors">
            Get in Touch
        </a>
    </div>

</div>
