@{
    ViewData["Title"] = "Contact";
}

<div class="max-w-6xl mx-auto px-6 py-16">

    <h1 class="text-3xl font-bold text-gray-900 mb-3">Contact</h1>
    <p class="text-gray-500 mb-14 max-w-lg">The fastest way to reach me is by phone. I answer calls and texts during business hours and do my best to respond same-day.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-14 max-w-2xl">

        <div>
            <p class="text-sm text-gray-400 mb-1">Phone / Text</p>
            <a href="tel:5551234567" class="text-2xl font-bold text-gray-900 hover:text-green-700 transition-colors">(555) 123-4567</a>
        </div>

        <div>
            <p class="text-sm text-gray-400 mb-1">Email</p>
            <a href="mailto:info@bugoff.com" class="text-lg font-medium text-gray-900 hover:text-green-700 transition-colors">info@bugoff.com</a>
        </div>

        <div>
            <p class="text-sm text-gray-400 mb-2">Hours</p>
            <p class="text-sm text-gray-700 leading-relaxed">
                Monday – Saturday<br>
                7:00 am – 7:00 pm
            </p>
            <p class="text-sm text-gray-400 mt-2">Closed Sundays</p>
        </div>

        <div>
            <p class="text-sm text-gray-400 mb-2">Service area</p>
            <p class="text-sm text-gray-700 leading-relaxed">Central Illinois within ~40 miles of Springfield.</p>
            <a asp-controller="Home" asp-action="ServiceArea"
               class="inline-block mt-2 text-sm text-green-700 hover:text-green-800 transition-colors">
                See full service area &rarr;
            </a>
        </div>

    </div>

    <div class="mt-14 pt-10 border-t border-gray-100">
        <p class="text-sm text-gray-500 mb-5">Prefer to book online?</p>
        <a asp-controller="ServiceRequest" asp-action="Create"
           class="inline-block bg-green-700 hover:bg-green-800 text-white font-medium px-7 py-3 rounded-xl text-sm transition-colors">
            Book a Service Call
        </a>
    </div>

</div>
