@{
    ViewData["Title"] = "About";
}

<div class="max-w-5xl mx-auto px-6 py-16">

    <h1 class="text-3xl font-bold text-gray-900 mb-2">About Us</h1>
    <p class="text-gray-500 mb-14">Family-owned and community-trusted since 2008.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

        <div>
            <p class="text-gray-600 leading-relaxed mb-5">
                BugOff Exterminators was founded by the Rodriguez family with a simple goal: give every homeowner access to professional, affordable, and responsible pest control.
            </p>
            <p class="text-gray-600 leading-relaxed mb-5">
                What started as a two-person operation in Springfield has grown into a trusted regional provider serving dozens of communities across central Illinois. We have helped thousands of families rest easier knowing their homes are protected.
            </p>
            <p class="text-gray-600 leading-relaxed">
                Every technician is state-licensed, background-checked, and trained in integrated pest management techniques that minimize chemical use while delivering lasting results.
            </p>
        </div>

        <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-6">Get in touch</h2>
            <dl class="space-y-5">
                <div>
                    <dt class="text-sm text-gray-400 mb-0.5">Phone</dt>
                    <dd class="text-gray-900">
                        <a href="tel:5551234567" class="hover:text-green-700 transition-colors">(555) 123-4567</a>
                        <span class="text-gray-400 text-sm ml-2">Mon&ndash;Sat, 7am&ndash;7pm</span>
                    </dd>
                </div>
                <div>
                    <dt class="text-sm text-gray-400 mb-0.5">Email</dt>
                    <dd class="text-gray-900">
                        <a href="mailto:info@bugoff.com" class="hover:text-green-700 transition-colors">info@bugoff.com</a>
                        <span class="text-gray-400 text-sm ml-2">We reply within 2 hours</span>
                    </dd>
                </div>
                <div>
                    <dt class="text-sm text-gray-400 mb-0.5">Service area</dt>
                    <dd class="text-gray-600 text-sm leading-relaxed">Springfield, Shelbyville, Capital City, and surrounding communities in central Illinois.</dd>
                </div>
            </dl>
            <div class="mt-10">
                <a asp-controller="ServiceRequest" asp-action="Create"
                   class="inline-block bg-green-700 hover:bg-green-800 text-white font-medium px-7 py-3.5 rounded-xl text-sm transition-colors">
                    Request a Service Visit
                </a>
            </div>
        </div>

    </div>

</div>
