@model AdminIndexViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@functions {
    string StatusBadge(ServiceStatus status) => status switch
    {
        ServiceStatus.New       => "bg-blue-100 text-blue-800",
        ServiceStatus.Scheduled => "bg-amber-100 text-amber-800",
        ServiceStatus.Completed => "bg-green-100 text-green-700",
        _                       => "bg-gray-100 text-gray-700"
    };
}

<!-- Page header -->
<section class="bg-green-800 text-white py-10 px-4">
    <div class="max-w-6xl mx-auto">
        <h1 class="text-3xl font-extrabold">Admin Dashboard</h1>
        <p class="text-green-300 mt-1 text-sm">All service requests — sorted by most recent.</p>
    </div>
</section>

<section class="py-10 px-4">
    <div class="max-w-6xl mx-auto">

        <!-- Stat cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
            <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-l-slate-400">
                <p class="text-3xl font-bold text-slate-900">@Model.TotalCount</p>
                <p class="text-sm text-slate-500 mt-1">Total Requests</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-l-blue-500">
                <p class="text-3xl font-bold text-slate-900">@Model.NewCount</p>
                <p class="text-sm text-slate-500 mt-1">New</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-l-amber-500">
                <p class="text-3xl font-bold text-slate-900">@Model.ScheduledCount</p>
                <p class="text-sm text-slate-500 mt-1">Scheduled</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-l-green-600">
                <p class="text-3xl font-bold text-slate-900">@Model.CompletedCount</p>
                <p class="text-sm text-slate-500 mt-1">Completed</p>
            </div>
        </div>

        <!-- Requests table -->
        @if (!Model.Requests.Any())
        {
            <div class="bg-white rounded-xl shadow-sm p-12 text-center text-slate-400">
                <p class="text-4xl mb-3">📋</p>
                <p class="font-medium">No service requests yet.</p>
                <a asp-controller="ServiceRequest" asp-action="Create"
                   class="inline-block mt-4 text-sm text-green-700 hover:underline">Be the first to submit one &rarr;</a>
            </div>
        }
        else
        {
            <div class="overflow-x-auto rounded-xl shadow-sm">
                <table class="w-full text-sm text-left text-slate-700 bg-white">
                    <thead>
                        <tr class="bg-green-700 text-white text-xs uppercase tracking-wide">
                            <th class="px-4 py-3">#</th>
                            <th class="px-4 py-3">Customer</th>
                            <th class="px-4 py-3 hidden sm:table-cell">Phone</th>
                            <th class="px-4 py-3">Pest</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3 hidden md:table-cell">Preferred Date</th>
                            <th class="px-4 py-3 hidden lg:table-cell">Submitted</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Requests)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50 cursor-pointer transition-colors"
                                onclick="window.location='/Admin/Details/@r.Id'">
                                <td class="px-4 py-3 font-mono text-slate-400 text-xs">#@r.Id</td>
                                <td class="px-4 py-3 font-medium text-slate-900">@r.CustomerName</td>
                                <td class="px-4 py-3 hidden sm:table-cell text-slate-500">@r.Phone</td>
                                <td class="px-4 py-3">@r.PestType.ToString().Replace("_", " ")</td>
                                <td class="px-4 py-3">
                                    <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold @StatusBadge(r.Status)">
                                        @r.Status
                                    </span>
                                </td>
                                <td class="px-4 py-3 hidden md:table-cell text-slate-500">
                                    @(r.PreferredDate.HasValue ? r.PreferredDate.Value.ToString("MMM d, yyyy") : "—")
                                </td>
                                <td class="px-4 py-3 hidden lg:table-cell text-slate-400 text-xs">
                                    @r.CreatedAt.ToString("MMM d, yyyy h:mm tt")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</section>
