@model AdminIndexViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@functions {
    string Badge(ServiceStatus s) => s switch
    {
        ServiceStatus.New       => "bg-blue-50 text-blue-600",
        ServiceStatus.Scheduled => "bg-amber-50 text-amber-700",
        ServiceStatus.Completed => "bg-green-50 text-green-700",
        _                       => "bg-gray-100 text-gray-500"
    };
}

<div class="max-w-6xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Service Requests</h1>
            <p class="text-gray-400 text-sm mt-1">
                @Model.TotalCount total &middot;
                @Model.NewCount new &middot;
                @Model.ScheduledCount scheduled &middot;
                @Model.CompletedCount completed
            </p>
        </div>
        <a asp-controller="ServiceRequest" asp-action="Create"
           class="self-start bg-green-700 hover:bg-green-800 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
            New Request
        </a>
    </div>

    <!-- Table -->
    @if (!Model.Requests.Any())
    {
        <p class="text-gray-400 py-12 text-center">No requests yet. <a asp-controller="ServiceRequest" asp-action="Create" class="text-green-700 hover:underline">Add the first one.</a></p>
    }
    else
    {
        <div class="overflow-x-auto rounded-2xl border border-gray-100">
            <table class="w-full text-sm text-left bg-white">
                <thead>
                    <tr class="border-b border-gray-100 text-gray-400 text-xs">
                        <th class="px-5 py-3.5 font-medium">#</th>
                        <th class="px-5 py-3.5 font-medium">Customer</th>
                        <th class="px-5 py-3.5 font-medium hidden sm:table-cell">Phone</th>
                        <th class="px-5 py-3.5 font-medium">Pest</th>
                        <th class="px-5 py-3.5 font-medium">Status</th>
                        <th class="px-5 py-3.5 font-medium hidden md:table-cell">Preferred Date</th>
                        <th class="px-5 py-3.5 font-medium hidden lg:table-cell">Submitted</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var r in Model.Requests)
                    {
                        <tr class="hover:bg-gray-50 cursor-pointer transition-colors"
                            onclick="window.location='/Admin/Details/@r.Id'">
                            <td class="px-5 py-4 text-gray-300 text-xs">@r.Id</td>
                            <td class="px-5 py-4 font-medium text-gray-900">@r.CustomerName</td>
                            <td class="px-5 py-4 text-gray-500 hidden sm:table-cell">@r.Phone</td>
                            <td class="px-5 py-4 text-gray-600">@r.PestType.ToString().Replace("_", " ")</td>
                            <td class="px-5 py-4">
                                <span class="text-xs font-medium px-2.5 py-1 rounded-lg @Badge(r.Status)">
                                    @r.Status
                                </span>
                            </td>
                            <td class="px-5 py-4 text-gray-400 hidden md:table-cell">
                                @(r.PreferredDate.HasValue ? r.PreferredDate.Value.ToString("MMM d, yyyy") : "—")
                            </td>
                            <td class="px-5 py-4 text-gray-400 text-xs hidden lg:table-cell">
                                @r.CreatedAt.ToString("MMM d, yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>
