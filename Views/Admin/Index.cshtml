@model AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";

    var jsonOpts = new System.Text.Json.JsonSerializerOptions
    {
        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
    };

    var calendarJson = System.Text.Json.JsonSerializer.Serialize(
        Model.WeekAppointments.Select(a => new
        {
            id = a.Id,
            customerName = a.CustomerName,
            pestType = a.PestType.ToString().Replace("_", " "),
            scheduledFor = a.ScheduledFor!.Value.ToString("o"),
            statusInt = (int)a.Status,
            status = a.Status.ToString()
        }), jsonOpts);

    var calendarMeta = System.Text.Json.JsonSerializer.Serialize(new
    {
        weekStart = Model.WeekStart.ToString("yyyy-MM-dd"),
        weekEnd = Model.WeekEnd.ToString("yyyy-MM-dd")
    }, jsonOpts);
}

<div class="admin-page">

    <!-- Summary cards -->
    <div class="admin-cards">

        <div class="admin-card">
            <div class="admin-card-icon admin-card-icon--blue">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <div class="admin-card-body">
                <div class="admin-card-label">Today</div>
                <div class="admin-card-value">@Model.TodayCount</div>
            </div>
        </div>

        <div class="admin-card">
            <div class="admin-card-icon admin-card-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M3 3h18v18H3zM3 9h18M9 21V9"/>
                </svg>
            </div>
            <div class="admin-card-body">
                <div class="admin-card-label">This Week</div>
                <div class="admin-card-value">@Model.WeekCount</div>
            </div>
        </div>

        <div class="admin-card @(Model.PendingCount > 0 ? "admin-card--warn" : "")">
            <div class="admin-card-icon admin-card-icon--amber">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
            <div class="admin-card-body">
                <div class="admin-card-label">
                    Pending @if (Model.PendingCount > 0) { <span class="admin-badge-warn">!</span> }
                </div>
                <div class="admin-card-value">@Model.PendingCount</div>
            </div>
        </div>

        <div class="admin-card">
            <div class="admin-card-icon admin-card-icon--green">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div class="admin-card-body">
                <div class="admin-card-label">Month Revenue</div>
                <div class="admin-card-value">$@Model.MonthRevenue.ToString("N0")</div>
            </div>
        </div>

    </div>

    <!-- Calendar + Timeline -->
    <div class="admin-two-col">

        <!-- Weekly calendar -->
        <div class="admin-surface admin-cal-section">
            <div class="admin-section-header">
                <h2 class="admin-section-title">
                    @Model.WeekStart.ToString("MMM d") – @Model.WeekEnd.ToString("MMM d, yyyy")
                </h2>
                <div class="admin-cal-nav">
                    <button id="cal-prev" class="admin-icon-btn" title="Previous week">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button id="cal-next" class="admin-icon-btn" title="Next week">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>
            </div>
            <div id="cal-grid" class="admin-cal-grid" aria-label="Weekly calendar"></div>
            <script id="calendarData" type="application/json">@Html.Raw(calendarJson)</script>
            <script id="calendarMeta" type="application/json">@Html.Raw(calendarMeta)</script>
        </div>

        <!-- Today's schedule timeline -->
        <div class="admin-surface admin-timeline-section">
            <h2 class="admin-section-title">Today's Schedule</h2>
            @if (!Model.TodaySchedule.Any())
            {
                <p class="admin-empty-state">No appointments today.</p>
            }
            else
            {
                <ul class="admin-timeline">
                    @foreach (var appt in Model.TodaySchedule)
                    {
                        <li class="admin-timeline-item" data-id="@appt.Id" role="button" tabindex="0"
                            aria-label="@appt.CustomerName at @appt.ScheduledFor?.ToString("h:mm tt")">
                            <span class="admin-timeline-time">@appt.ScheduledFor?.ToString("h:mm tt")</span>
                            <span class="admin-timeline-name">@appt.CustomerName</span>
                            <span class="admin-status-badge admin-status-@appt.Status.ToString().ToLower()">@appt.Status</span>
                        </li>
                    }
                </ul>
            }
        </div>

    </div>

    <!-- All requests table -->
    <div class="admin-surface admin-table-section">
        <div class="admin-section-header admin-section-header--wrap">
            <h2 class="admin-section-title">All Requests</h2>
            <div class="admin-filter-pills" role="group" aria-label="Filter by status">
                <button class="admin-filter-pill is-active" data-filter="all">All</button>
                <button class="admin-filter-pill" data-filter="New">New</button>
                <button class="admin-filter-pill" data-filter="Scheduled">Scheduled</button>
                <button class="admin-filter-pill" data-filter="Completed">Completed</button>
                <button class="admin-filter-pill" data-filter="Cancelled">Cancelled</button>
            </div>
        </div>

        @if (!Model.AllRequests.Any())
        {
            <p class="admin-empty-state">
                No requests yet. <a href="/ServiceRequest/Create" class="admin-link">Add the first one.</a>
            </p>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Pest</th>
                            <th>Status</th>
                            <th>Scheduled</th>
                            <th class="admin-th-date">Submitted</th>
                        </tr>
                    </thead>
                    <tbody id="requests-tbody">
                        @foreach (var r in Model.AllRequests)
                        {
                            <tr class="admin-table-row" data-id="@r.Id" data-status="@r.Status.ToString()"
                                role="button" tabindex="0" aria-label="Open @r.CustomerName appointment">
                                <td class="admin-td-name">@r.CustomerName</td>
                                <td class="admin-td-pest">@r.PestType.ToString().Replace("_", " ")</td>
                                <td>
                                    <span class="admin-status-badge admin-status-@r.Status.ToString().ToLower()">@r.Status</span>
                                </td>
                                <td class="admin-td-sched">
                                    @(r.ScheduledFor.HasValue ? r.ScheduledFor.Value.ToString("MMM d, h:mm tt") : "—")
                                </td>
                                <td class="admin-td-date admin-th-date">@r.CreatedAt.ToString("MMM d, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
