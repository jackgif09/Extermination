@model AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["TodayNewCount"] = Model.TodayNewCount;
    ViewData["UpcomingNewCount"] = Model.UpcomingNewCount;
    ViewData["ShowTabBar"] = true;
}

<div class="tab-panels">

    @* ── TODAY ──────────────────────────────────────────────────────────────── *@
    <section id="panel-today" class="tab-panel" data-panel="today">

        <div class="day-hero">
            <div class="day-hero-count">
                <span class="day-hero-num">@Model.TodayCount</span>
                <span class="day-hero-label">appointment@(Model.TodayCount == 1 ? "" : "s") today</span>
            </div>
            @if (Model.NextAppointment != null)
            {
                var n = Model.NextAppointment;
                string when;
                if (!n.ScheduledFor.HasValue)
                    when = "unscheduled";
                else if (n.ScheduledFor.Value.Date == DateTime.Today)
                    when = n.ScheduledFor.Value.ToString("h:mm tt");
                else
                    when = n.ScheduledFor.Value.ToString("MMM d, h:mm tt");
                <div class="day-hero-next">
                    <span class="next-label">Next up</span>
                    <span class="next-detail">@n.CustomerName &middot; @when</span>
                </div>
            }
        </div>

        @if (!Model.TodaySchedule.Any())
        {
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <p>No appointments scheduled for today.</p>
                <a href="/Admin/Create" class="empty-add-link">+ Add one</a>
            </div>
        }
        else
        {
            <div class="appt-list">
                @foreach (var r in Model.TodaySchedule)
                {
                    await Html.RenderPartialAsync("_AppointmentCard", (Request: r, ShowDate: false));
                }
            </div>
        }

    </section>

    @* ── UPCOMING ────────────────────────────────────────────────────────────── *@
    <section id="panel-upcoming" class="tab-panel" data-panel="upcoming" hidden>

        @if (!Model.UpcomingRequests.Any())
        {
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <p>No upcoming appointments.</p>
                <a href="/Admin/Create" class="empty-add-link">+ Add one</a>
            </div>
        }
        else
        {
            <div class="appt-list">
                @foreach (var r in Model.UpcomingRequests)
                {
                    await Html.RenderPartialAsync("_AppointmentCard", (Request: r, ShowDate: true));
                }
            </div>
        }

    </section>

    @* ── PAST ────────────────────────────────────────────────────────────────── *@
    <section id="panel-past" class="tab-panel" data-panel="past" hidden>

        @if (!Model.PastRequests.Any())
        {
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <p>No past appointments yet.</p>
            </div>
        }
        else
        {
            <div class="appt-list">
                @foreach (var r in Model.PastRequests)
                {
                    await Html.RenderPartialAsync("_AppointmentCard", (Request: r, ShowDate: true));
                }
            </div>
        }

    </section>

</div>
