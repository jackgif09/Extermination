@model AdminIndexViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@functions {
    string BadgeClasses(ServiceStatus status) => status switch
    {
        ServiceStatus.New       => "bg-blue-50 text-blue-700 border-blue-200",
        ServiceStatus.Scheduled => "bg-amber-50 text-amber-700 border-amber-200",
        ServiceStatus.Completed => "bg-green-50 text-green-800 border-green-200",
        _                       => "bg-gray-50 text-gray-600 border-gray-200"
    };
}

<!-- Page header -->
<div class="bg-white border-b border-gray-200 px-6 py-10">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-green-800 mb-2">Admin</p>
            <h1 class="text-3xl font-bold text-gray-900">Service Requests</h1>
        </div>
        <a asp-controller="ServiceRequest" asp-action="Create"
           class="self-start sm:self-auto bg-green-800 hover:bg-green-900 text-white text-sm font-medium px-5 py-2.5 rounded transition-colors">
            New Request
        </a>
    </div>
</div>

<div class="bg-gray-50 px-6 py-10 min-h-full">
    <div class="max-w-6xl mx-auto">

        <!-- Stat cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
            <div class="bg-white border border-gray-200 rounded p-5">
                <p class="text-2xl font-bold text-gray-900">@Model.TotalCount</p>
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mt-1">Total</p>
            </div>
            <div class="bg-white border border-gray-200 rounded p-5 border-t-2 border-t-blue-500">
                <p class="text-2xl font-bold text-gray-900">@Model.NewCount</p>
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mt-1">New</p>
            </div>
            <div class="bg-white border border-gray-200 rounded p-5 border-t-2 border-t-amber-500">
                <p class="text-2xl font-bold text-gray-900">@Model.ScheduledCount</p>
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mt-1">Scheduled</p>
            </div>
            <div class="bg-white border border-gray-200 rounded p-5 border-t-2 border-t-green-700">
                <p class="text-2xl font-bold text-gray-900">@Model.CompletedCount</p>
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mt-1">Completed</p>
            </div>
        </div>

        <!-- Table -->
        @if (!Model.Requests.Any())
        {
            <div class="bg-white border border-gray-200 rounded p-12 text-center">
                <p class="font-medium text-gray-900 mb-1">No service requests yet</p>
                <p class="text-sm text-gray-400 mb-5">Submitted requests will appear here.</p>
                <a asp-controller="ServiceRequest" asp-action="Create"
                   class="inline-block text-sm font-medium text-green-800 hover:text-green-900 underline underline-offset-2">
                    Submit the first request
                </a>
            </div>
        }
        else
        {
            <div class="bg-white border border-gray-200 rounded overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-gray-700">
                        <thead>
                            <tr class="border-b border-gray-200 bg-gray-50">
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500">#</th>
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500">Customer</th>
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500 hidden sm:table-cell">Phone</th>
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500">Pest Type</th>
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500 hidden md:table-cell">Preferred Date</th>
                                <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wide text-gray-500 hidden lg:table-cell">Submitted</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var r in Model.Requests)
                            {
                                <tr class="hover:bg-gray-50 cursor-pointer transition-colors"
                                    onclick="window.location='/Admin/Details/@r.Id'">
                                    <td class="px-5 py-4 text-gray-400 font-mono text-xs">@r.Id</td>
                                    <td class="px-5 py-4 font-medium text-gray-900">@r.CustomerName</td>
                                    <td class="px-5 py-4 text-gray-500 hidden sm:table-cell">@r.Phone</td>
                                    <td class="px-5 py-4 text-gray-600">@r.PestType.ToString().Replace("_", " ")</td>
                                    <td class="px-5 py-4">
                                        <span class="inline-block text-xs font-medium px-2 py-0.5 rounded border @BadgeClasses(r.Status)">
                                            @r.Status
                                        </span>
                                    </td>
                                    <td class="px-5 py-4 text-gray-500 hidden md:table-cell">
                                        @(r.PreferredDate.HasValue ? r.PreferredDate.Value.ToString("MMM d, yyyy") : "—")
                                    </td>
                                    <td class="px-5 py-4 text-gray-400 text-xs hidden lg:table-cell">
                                        @r.CreatedAt.ToString("MMM d, yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
</div>
