@model ServiceRequest
@{
    ViewData["Title"] = $"Request #{Model.Id}";

    string badge = Model.Status switch
    {
        ServiceStatus.New       => "bg-blue-50 text-blue-600",
        ServiceStatus.Scheduled => "bg-amber-50 text-amber-700",
        ServiceStatus.Completed => "bg-green-50 text-green-700",
        _                       => "bg-gray-100 text-gray-500"
    };
}

<div class="max-w-5xl mx-auto px-6 py-10">

    <a asp-controller="Admin" asp-action="Index"
       class="text-sm text-gray-600 hover:text-gray-900 transition-colors mb-8 inline-block">
        &larr; All requests
    </a>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-10">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">@Model.CustomerName</h1>
            <p class="text-gray-600 text-sm mt-1">Submitted @Model.CreatedAt.ToString("MMMM d, yyyy")</p>
        </div>
        <span class="self-start text-xs font-medium px-3 py-1.5 rounded-lg @badge">@Model.Status</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

        <!-- Details -->
        <div class="md:col-span-2 space-y-10">

            <dl class="space-y-5 text-sm">
                <div class="flex gap-6">
                    <dt class="w-28 shrink-0 text-gray-600">Phone</dt>
                    <dd><a href="tel:@Model.Phone" class="text-gray-900 hover:text-green-700 transition-colors">@Model.Phone</a></dd>
                </div>
                <div class="flex gap-6">
                    <dt class="w-28 shrink-0 text-gray-600">Email</dt>
                    <dd><a href="mailto:@Model.Email" class="text-gray-900 hover:text-green-700 transition-colors">@Model.Email</a></dd>
                </div>
                <div class="flex gap-6">
                    <dt class="w-28 shrink-0 text-gray-600">Address</dt>
                    <dd class="text-gray-700 leading-relaxed">@Model.Address</dd>
                </div>
                <div class="flex gap-6">
                    <dt class="w-28 shrink-0 text-gray-600">Pest type</dt>
                    <dd class="text-gray-700">@Model.PestType.ToString().Replace("_", " ")</dd>
                </div>
                <div class="flex gap-6">
                    <dt class="w-28 shrink-0 text-gray-600">Preferred date</dt>
                    <dd class="text-gray-700">
                        @(Model.PreferredDate.HasValue ? Model.PreferredDate.Value.ToString("MMMM d, yyyy") : "Not specified")
                    </dd>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="flex gap-6">
                        <dt class="w-28 shrink-0 text-gray-600 pt-0.5">Description</dt>
                        <dd class="text-gray-700 leading-relaxed">@Model.Description</dd>
                    </div>
                }
            </dl>

            <!-- Internal notes -->
            <div>
                <h2 class="text-sm font-semibold text-gray-900 mb-3">Internal notes</h2>
                <form asp-action="UpdateNotes" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <textarea name="notes" rows="5"
                              placeholder="Add notes visible only to you — scheduling details, access instructions, follow-up reminders, etc."
                              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 bg-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition resize-y">@Model.Notes</textarea>
                    <button type="submit"
                            class="mt-2 bg-gray-900 hover:bg-gray-700 text-white font-medium py-2.5 px-5 rounded-xl text-sm transition-colors">
                        Save notes
                    </button>
                </form>
            </div>

        </div>

        <!-- Status update -->
        <div>
            <h2 class="text-sm font-semibold text-gray-900 mb-4">Update status</h2>
            <form asp-action="UpdateStatus" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <select name="status"
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition mb-3">
                    @foreach (var s in Enum.GetValues<ServiceStatus>())
                    {
                        if (s == Model.Status)
                        {
                            <option value="@s" selected>@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                </select>
                <button type="submit"
                        class="w-full bg-green-700 hover:bg-green-800 text-white font-medium py-3 rounded-xl text-sm transition-colors">
                    Save
                </button>
            </form>
        </div>

    </div>

</div>
