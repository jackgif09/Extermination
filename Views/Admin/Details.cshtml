@model ServiceRequest
@{
    ViewData["Title"] = $"Request #{Model.Id}";

    string badgeClass = Model.Status switch
    {
        ServiceStatus.New       => "bg-blue-100 text-blue-800",
        ServiceStatus.Scheduled => "bg-amber-100 text-amber-800",
        ServiceStatus.Completed => "bg-green-100 text-green-700",
        _                       => "bg-gray-100 text-gray-700"
    };
}

<!-- Page header -->
<section class="bg-green-800 text-white py-10 px-4">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <p class="text-green-400 text-sm mb-1">Service Request</p>
            <h1 class="text-3xl font-extrabold">@Model.CustomerName</h1>
            <p class="text-green-300 text-sm mt-1">Submitted @Model.CreatedAt.ToString("MMMM d, yyyy \\a\\t h:mm tt") UTC</p>
        </div>
        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold self-start sm:self-auto @badgeClass">
            @Model.Status
        </span>
    </div>
</section>

<section class="py-10 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Request details (2/3 width) -->
        <div class="md:col-span-2 space-y-5">
            <div class="bg-white rounded-2xl shadow-sm p-7">
                <h2 class="text-lg font-bold text-slate-900 mb-5 border-b pb-3">Request Details</h2>

                <dl class="space-y-4">
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Reference #</dt>
                        <dd class="text-sm font-mono text-slate-700">#@Model.Id</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Customer Name</dt>
                        <dd class="text-sm text-slate-900 font-medium">@Model.CustomerName</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Phone</dt>
                        <dd class="text-sm"><a href="tel:@Model.Phone" class="text-green-700 hover:underline">@Model.Phone</a></dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Email</dt>
                        <dd class="text-sm"><a href="mailto:@Model.Email" class="text-green-700 hover:underline">@Model.Email</a></dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Address</dt>
                        <dd class="text-sm text-slate-700">@Model.Address</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Pest Type</dt>
                        <dd class="text-sm text-slate-700">@Model.PestType.ToString().Replace("_", " ")</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Preferred Date</dt>
                        <dd class="text-sm text-slate-700">
                            @(Model.PreferredDate.HasValue ? Model.PreferredDate.Value.ToString("MMMM d, yyyy") : "—")
                        </dd>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <dt class="text-xs uppercase font-semibold text-slate-400">Current Status</dt>
                        <dd>
                            <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold @badgeClass">@Model.Status</span>
                        </dd>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <div class="pt-2 border-t">
                            <dt class="text-xs uppercase font-semibold text-slate-400 mb-2">Description</dt>
                            <dd class="text-sm text-slate-700 leading-relaxed bg-gray-50 rounded-lg p-3">@Model.Description</dd>
                        </div>
                    }
                </dl>
            </div>
        </div>

        <!-- Status panel (1/3 width) -->
        <div class="space-y-5">
            <div class="bg-white rounded-2xl shadow-sm p-7">
                <h2 class="text-lg font-bold text-slate-900 mb-5 border-b pb-3">Update Status</h2>
                <form asp-action="UpdateStatus" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="block text-sm font-medium text-slate-700 mb-2">New Status</label>
                    <select name="status"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-green-600 transition bg-white text-sm mb-4">
                        @foreach (var s in Enum.GetValues<ServiceStatus>())
                        {
                            if (s == Model.Status)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                    <button type="submit"
                            class="w-full bg-green-700 hover:bg-green-800 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">
                        Save Status
                    </button>
                </form>
            </div>

            <!-- Back link -->
            <a asp-controller="Admin" asp-action="Index"
               class="flex items-center justify-center gap-2 w-full border border-slate-300 hover:border-slate-400 text-slate-600 font-medium py-2.5 rounded-lg text-sm transition-colors">
                &larr; Back to Dashboard
            </a>
        </div>

    </div>
</section>
